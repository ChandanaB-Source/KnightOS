# ── Server ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB Atlas ───────────────────────────────────────────────
# Steps: cloud.mongodb.com → New Cluster (Free) → Connect → Drivers → copy URI
MONGODB_URI=mongodb+srv://chessadmin:Chess1234@cluster-1.cz6ib5z.mongodb.net/knightos?retryWrites=true&w=majority&appName=Cluster-1

# ── JWT (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=replace_with_64_random_hex_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_another_64_random_hex_chars
JWT_REFRESH_EXPIRES_IN=30d

# ── CORS ────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
